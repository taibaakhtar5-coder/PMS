@{
    ViewData["Title"] = "Prescriptions";
}

<div class="space-y-6 animate-auth">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-heading font-extrabold text-white tracking-tight">Prescriptions</h1>
            <p class="text-slate-400 text-sm">Manage patient prescriptions and medications</p>
        </div>
        <button id="create-rx-btn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 transition-all hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            New Prescription
        </button>
    </div>

    <!-- Filters -->
    <div class="bg-brand-card border border-white/5 rounded-2xl p-4 shadow-xl">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div>
                <label class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Patient</label>
                <select id="filter-patient" style="color-scheme:dark;background-color:#141d36;color:#e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary transition-all text-sm">
                    <option value="" style="background-color:#141d36;color:#e2e8f0;">All Patients</option>
                </select>
            </div>
            <div>
                <label class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Status</label>
                <select id="filter-status" style="color-scheme:dark;background-color:#141d36;color:#e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary transition-all text-sm">
                    <option value="" style="background-color:#141d36;color:#e2e8f0;">All</option>
                    <option value="Active" style="background-color:#141d36;color:#e2e8f0;">Active</option>
                    <option value="Expired" style="background-color:#141d36;color:#e2e8f0;">Expired</option>
                    <option value="Cancelled" style="background-color:#141d36;color:#e2e8f0;">Cancelled</option>
                </select>
            </div>
            <div class="flex items-end">
                <button id="clear-filters" class="w-full px-3 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Clear Filters</button>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-brand-card border border-white/5 rounded-2xl p-6 shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="border-b border-white/5 text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="pb-3 pr-4">Patient</th>
                        <th class="pb-3 px-4">Doctor</th>
                        <th class="pb-3 px-4">Date</th>
                        <th class="pb-3 px-4">Medicines</th>
                        <th class="pb-3 px-4">Valid Until</th>
                        <th class="pb-3 px-4">Status</th>
                        <th class="pb-3 pl-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="rx-table-body" class="divide-y divide-white/5">
                    <tr><td colspan="7" class="py-12 text-center text-slate-500">
                        <span class="inline-block w-8 h-8 border-2 border-brand-primary border-r-transparent rounded-full animate-spin"></span>
                        <p class="mt-2 text-xs font-semibold">Loading prescriptions...</p>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Prescription Modal -->
<div id="rx-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="rx-modal-backdrop"></div>
    <div class="relative bg-[#0f172a] border border-white/10 rounded-2xl shadow-2xl p-6 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-lg font-heading font-bold text-white">New Prescription</h3>
            <button id="rx-modal-close" class="text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div id="rx-alert" class="hidden text-sm p-4 rounded-xl border mb-4"></div>
        <div class="flex flex-col gap-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Patient *</label>
                    <select id="rx-patientId" style="color-scheme:dark;background-color:#141d36;color:#e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required>
                        <option value="" style="background-color:#141d36;color:#e2e8f0;">Choose Patient</option>
                    </select>
                    <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="rx-patient-error"></div>
                </div>
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Doctor Name *</label>
                    <input type="text" id="rx-doctorName" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm" placeholder="Dr. Ahmed Khan" />
                    <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="rx-doctor-error"></div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Diagnosis</label>
                    <input type="text" id="rx-diagnosis" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm" placeholder="e.g. Hypertension" />
                </div>
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Valid Until</label>
                    <input type="date" id="rx-validUntil" style="color-scheme:dark;" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" />
                </div>
            </div>

            <!-- Medicine Items -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <label class="text-slate-300 text-xs font-semibold uppercase tracking-wider">Medications *</label>
                    <button type="button" id="add-med-btn" class="text-xs font-semibold text-brand-primary hover:text-brand-accent transition-colors flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add Medicine
                    </button>
                </div>
                <div id="med-container" class="flex flex-col gap-2"></div>
                <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="rx-med-error"></div>
            </div>

            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Notes</label>
                <textarea id="rx-notes" rows="2" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm resize-none" placeholder="Additional instructions..."></textarea>
            </div>

            <div class="flex gap-3 mt-2">
                <button id="rx-modal-cancel" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Cancel</button>
                <button id="rx-modal-save" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
                    <span class="btn-text">Save Prescription</span>
                    <span class="btn-spinner hidden w-4 h-4 border-2 border-white border-r-transparent rounded-full animate-spin"></span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('jwt_token');
    const tableBody = document.getElementById('rx-table-body');
    const filterPatient = document.getElementById('filter-patient');
    const filterStatus = document.getElementById('filter-status');
    const rxModal = document.getElementById('rx-modal');
    const rxAlert = document.getElementById('rx-alert');

    function authHeaders(json = false) {
        const h = {};
        if (token) h['Authorization'] = `Bearer ${token}`;
        if (json) h['Content-Type'] = 'application/json';
        return h;
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
    }

    function statusBadge(status) {
        const map = {
            'Active':    'bg-emerald-500/10 border-emerald-500/20 text-emerald-400',
            'Expired':   'bg-amber-500/10 border-amber-500/20 text-amber-400',
            'Cancelled': 'bg-rose-500/10 border-rose-500/20 text-rose-400'
        };
        return `<span class="inline-flex px-2.5 py-1 text-xs font-semibold rounded-lg border ${map[status] || 'bg-white/10 border-white/10 text-slate-300'}">${escapeHtml(status)}</span>`;
    }

    async function fetchPrescriptions() {
        try {
            const params = new URLSearchParams();
            if (filterPatient.value) params.set('patientId', filterPatient.value);
            if (filterStatus.value) params.set('status', filterStatus.value);
            const res = await fetch('/api/prescriptions' + (params.toString() ? `?${params}` : ''), { headers: authHeaders() });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            const result = await res.json();
            if (res.ok && result.success) renderTable(result.data);
            else tableBody.innerHTML = `<tr><td colspan="7" class="py-12 text-center text-red-400 text-sm">${escapeHtml(result.message)}</td></tr>`;
        } catch { tableBody.innerHTML = `<tr><td colspan="7" class="py-12 text-center text-red-400 text-sm">Network error.</td></tr>`; }
    }

    function renderTable(rxList) {
        if (!rxList || rxList.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="7" class="py-12 text-center text-slate-500 text-sm">No prescriptions found.</td></tr>`;
            return;
        }
        tableBody.innerHTML = rxList.map(rx => {
            const date = new Date(rx.prescribedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            const validUntil = rx.validUntil ? new Date(rx.validUntil).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';
            const medCount = rx.items ? rx.items.length : 0;
            return `
            <tr class="hover:bg-white/5 transition-colors">
                <td class="py-4 pr-4 font-semibold text-slate-200">${escapeHtml(rx.patient?.fullName || 'N/A')}</td>
                <td class="py-4 px-4 text-xs text-slate-300">Dr. ${escapeHtml(rx.doctorName)}</td>
                <td class="py-4 px-4 text-xs text-slate-400">${date}</td>
                <td class="py-4 px-4 text-xs text-slate-300">${medCount} medicine(s)</td>
                <td class="py-4 px-4 text-xs text-slate-400">${validUntil}</td>
                <td class="py-4 px-4">${statusBadge(rx.status)}</td>
                <td class="py-4 pl-4 text-right">
                    <div class="flex items-center justify-end gap-3">
                        <a href="/Prescription/Detail/${rx.id}" class="text-xs font-bold text-brand-primary hover:text-brand-accent transition-colors">View</a>
                        ${rx.status === 'Active' ? `<button onclick="cancelRx('${rx.id}')" class="text-xs font-bold text-rose-400 hover:text-rose-300 transition-colors">Cancel</button>` : ''}
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    async function loadPatients() {
        try {
            const res = await fetch('/api/patients', { headers: authHeaders() });
            const result = await res.json();
            if (res.ok && result.success) {
                const opts = result.data.map(p => `<option value="${p.id}" style="background-color:#141d36;color:#e2e8f0;">${escapeHtml(p.fullName)}</option>`).join('');
                filterPatient.innerHTML = `<option value="" style="background-color:#141d36;color:#e2e8f0;">All Patients</option>` + opts;
                document.getElementById('rx-patientId').innerHTML = `<option value="" style="background-color:#141d36;color:#e2e8f0;">Choose Patient</option>` + opts;
            }
        } catch {}
    }

    // Medicine rows
    function addMedRow() {
        const row = document.createElement('div');
        row.className = 'med-row grid grid-cols-12 gap-2 items-start p-3 bg-white/5 rounded-xl border border-white/5';
        row.innerHTML = `
            <div class="col-span-4">
                <input type="text" placeholder="Medicine name *" class="med-name w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-brand-primary text-xs placeholder:text-slate-600" />
            </div>
            <div class="col-span-2">
                <input type="text" placeholder="Dosage" class="med-dosage w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-brand-primary text-xs placeholder:text-slate-600" />
            </div>
            <div class="col-span-2">
                <input type="text" placeholder="Frequency" class="med-frequency w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-brand-primary text-xs placeholder:text-slate-600" />
            </div>
            <div class="col-span-2">
                <input type="text" placeholder="Duration" class="med-duration w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-slate-200 focus:outline-none focus:border-brand-primary text-xs placeholder:text-slate-600" />
            </div>
            <div class="col-span-1 flex items-center justify-center pt-1">
                <button class="remove-med text-slate-500 hover:text-rose-400 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>`;
        row.querySelector('.remove-med').addEventListener('click', () => row.remove());
        document.getElementById('med-container').appendChild(row);
    }

    document.getElementById('add-med-btn').addEventListener('click', addMedRow);

    // Modal
    function openModal() {
        rxModal.classList.remove('hidden');
        rxAlert.className = 'hidden text-sm p-4 rounded-xl border mb-4';
        document.getElementById('med-container').innerHTML = '';
        addMedRow();
    }
    function closeModal() { rxModal.classList.add('hidden'); }
    document.getElementById('create-rx-btn').addEventListener('click', openModal);
    document.getElementById('rx-modal-close').addEventListener('click', closeModal);
    document.getElementById('rx-modal-cancel').addEventListener('click', closeModal);
    document.getElementById('rx-modal-backdrop').addEventListener('click', closeModal);

    document.getElementById('rx-modal-save').addEventListener('click', async () => {
        const patientId = document.getElementById('rx-patientId').value;
        const doctorName = document.getElementById('rx-doctorName').value.trim();
        const diagnosis = document.getElementById('rx-diagnosis').value.trim();
        const validUntil = document.getElementById('rx-validUntil').value;
        const notes = document.getElementById('rx-notes').value.trim();
        document.getElementById('rx-patient-error').textContent = '';
        document.getElementById('rx-doctor-error').textContent = '';
        document.getElementById('rx-med-error').textContent = '';

        let valid = true;
        if (!patientId) { document.getElementById('rx-patient-error').textContent = 'Please select a patient.'; valid = false; }
        if (!doctorName) { document.getElementById('rx-doctor-error').textContent = 'Doctor name is required.'; valid = false; }

        const items = [];
        document.querySelectorAll('.med-row').forEach(row => {
            const name = row.querySelector('.med-name').value.trim();
            if (name) items.push({
                medicineName: name,
                dosage: row.querySelector('.med-dosage').value.trim() || null,
                frequency: row.querySelector('.med-frequency').value.trim() || null,
                duration: row.querySelector('.med-duration').value.trim() || null,
                instructions: null
            });
        });
        if (items.length === 0) { document.getElementById('rx-med-error').textContent = 'Add at least one medicine.'; valid = false; }
        if (!valid) return;

        const btn = document.getElementById('rx-modal-save');
        const btnText = btn.querySelector('.btn-text');
        const btnSpinner = btn.querySelector('.btn-spinner');
        btn.disabled = true; btnText.classList.add('hidden'); btnSpinner.classList.remove('hidden');

        try {
            const res = await fetch('/api/prescriptions', {
                method: 'POST',
                headers: authHeaders(true),
                body: JSON.stringify({ patientId, doctorName, diagnosis: diagnosis || null, validUntil: validUntil || null, notes: notes || null, items })
            });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            const result = await res.json();
            if (res.ok && result.success) { closeModal(); fetchPrescriptions(); }
            else {
                rxAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
                rxAlert.textContent = result.message || 'Failed to save.';
            }
        } catch {
            rxAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
            rxAlert.textContent = 'An error occurred.';
        } finally {
            btn.disabled = false; btnText.classList.remove('hidden'); btnSpinner.classList.add('hidden');
        }
    });

    window.cancelRx = async function(id) {
        if (!confirm('Cancel this prescription?')) return;
        try {
            const res = await fetch(`/api/prescriptions/${id}/status`, {
                method: 'PATCH',
                headers: authHeaders(true),
                body: JSON.stringify({ status: 'Cancelled' })
            });
            const result = await res.json();
            if (res.ok && result.success) fetchPrescriptions();
            else alert(result.message || 'Failed.');
        } catch { alert('Error occurred.'); }
    };

    filterPatient.addEventListener('change', fetchPrescriptions);
    filterStatus.addEventListener('change', fetchPrescriptions);
    document.getElementById('clear-filters').addEventListener('click', () => {
        filterPatient.value = ''; filterStatus.value = '';
        fetchPrescriptions();
    });

    loadPatients();
    fetchPrescriptions();
    setInterval(fetchPrescriptions, 8000);
});
</script>
}
