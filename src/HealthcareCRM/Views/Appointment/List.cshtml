@{
    ViewData["Title"] = "Appointments";
}

<div class="space-y-6 animate-auth">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-heading font-extrabold text-white tracking-tight">Appointments Schedule</h1>
            <p class="text-slate-400 text-sm">Monitor and schedule clinical consultations and patient visits</p>
        </div>
        <div>
            <button id="open-modal-btn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 hover:shadow-brand-primary/35 transition-all hover:-translate-y-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                <span>Schedule Appointment</span>
            </button>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="bg-brand-card backdrop-blur-md border border-white/5 rounded-2xl p-4 shadow-xl">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <div>
                <label for="filter-doctor" class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Doctor</label>
                <select id="filter-doctor" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm">
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">All Doctors</option>
                </select>
            </div>
            <div>
                <label for="filter-status" class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Status</label>
                <select id="filter-status" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm">
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">All Statuses</option>
                    <option value="Scheduled" style="background-color: #141d36; color: #e2e8f0;">Scheduled</option>
                    <option value="Completed" style="background-color: #141d36; color: #e2e8f0;">Completed</option>
                    <option value="Cancelled" style="background-color: #141d36; color: #e2e8f0;">Cancelled</option>
                </select>
            </div>
            <div>
                <label for="filter-date" class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Date</label>
                <input type="date" id="filter-date" style="color-scheme: dark;" class="w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" />
            </div>
            <div class="flex items-end">
                <button id="clear-filters-btn" class="w-full px-3 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="bg-brand-card backdrop-blur-md border border-white/5 rounded-2xl p-6 shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="border-b border-white/5 text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="pb-3 pr-4">Time & Date</th>
                        <th class="pb-3 px-4">Patient</th>
                        <th class="pb-3 px-4">Assigned Doctor</th>
                        <th class="pb-3 px-4">Reason</th>
                        <th class="pb-3 pl-4 text-right">Status</th>
                    </tr>
                </thead>
                <tbody id="appointments-table-body" class="divide-y divide-white/5 align-middle">
                    <tr>
                        <td colspan="5" class="py-12 text-center text-slate-500">
                            <span class="inline-block w-8 h-8 border-2 border-brand-primary border-r-transparent rounded-full animate-spin"></span>
                            <p class="mt-2 text-xs font-semibold">Loading schedule...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Glassmorphic Booking Modal -->
<div id="booking-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-[#070a12]/80 backdrop-blur-sm" id="modal-backdrop"></div>

    <!-- Modal Card -->
    <div class="bg-[#0f172a] border border-white/10 rounded-2xl shadow-2xl p-8 w-full max-w-lg relative z-10 animate-auth max-h-[90vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-heading font-bold text-white">Schedule Appointment</h2>
            <button id="close-modal-btn" class="text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <div id="modal-alert" class="hidden text-sm p-4 rounded-xl mb-4 border"></div>

        <form id="appointment-form" novalidate class="flex flex-col gap-4">
            <div>
                <label for="patientId" class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Select Patient *</label>
                <select id="patientId" name="PatientId" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required>
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">Loading patients...</option>
                </select>
                <div class="text-red-400 text-xs font-medium mt-1.5 min-h-[18px] ml-1" id="patientId-error"></div>
            </div>

            <div>
                <label for="doctorId" class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Assigned Doctor *</label>
                <select id="doctorId" name="DoctorId" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required>
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">Loading doctors...</option>
                </select>
                <div class="text-red-400 text-xs font-medium mt-1.5 min-h-[18px] ml-1" id="doctorId-error"></div>
            </div>

            <div>
                <label for="appointmentDate" class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Appointment Date & Time *</label>
                <input type="datetime-local" id="appointmentDate" name="AppointmentDate" style="color-scheme: dark;" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required />
                <div class="text-red-400 text-xs font-medium mt-1.5 min-h-[18px] ml-1" id="appointmentDate-error"></div>
            </div>

            <div>
                <label for="durationMinutes" class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Duration *</label>
                <select id="durationMinutes" name="DurationMinutes" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required>
                    <option value="15" style="background-color: #141d36; color: #e2e8f0;">15 minutes</option>
                    <option value="30" selected style="background-color: #141d36; color: #e2e8f0;">30 minutes</option>
                    <option value="45" style="background-color: #141d36; color: #e2e8f0;">45 minutes</option>
                    <option value="60" style="background-color: #141d36; color: #e2e8f0;">60 minutes</option>
                </select>
                <p class="text-slate-500 text-xs mt-1.5 ml-1">A 45-minute gap is required between this doctor's appointments.</p>
            </div>

            <!-- Live Availability Panel -->
            <div id="availability-panel" class="hidden bg-white/5 border border-white/10 rounded-xl p-3.5">
                <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span class="text-xs font-semibold text-slate-300">Doctor's schedule for selected date</span>
                </div>
                <div id="availability-content" class="text-xs text-slate-400">Select a doctor and date to see booked slots.</div>
            </div>

            <div>
                <label for="reason" class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Reason for Visit</label>
                <textarea id="reason" name="Reason" rows="3" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm resize-none" placeholder="Routine general health checkup..."></textarea>
                <div class="text-red-400 text-xs font-medium mt-1.5 min-h-[18px] ml-1" id="reason-error"></div>
            </div>

            <div class="flex justify-end gap-3 mt-4">
                <button type="button" id="cancel-modal-btn" class="px-5 py-3 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Cancel</button>
                <button type="submit" id="submit-btn" class="px-6 py-3 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 hover:shadow-brand-primary/35 hover:-translate-y-0.5 active:translate-y-0 disabled:opacity-75 disabled:cursor-not-allowed transition-all flex items-center gap-2">
                    <span class="btn-text">Confirm Booking</span>
                    <span class="btn-spinner hidden w-5 h-5 border-2 border-white border-r-transparent rounded-full animate-spin"></span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.getElementById('appointments-table-body');
            const filterDoctor = document.getElementById('filter-doctor');
            const filterStatus = document.getElementById('filter-status');
            const filterDate = document.getElementById('filter-date');
            const clearFiltersBtn = document.getElementById('clear-filters-btn');
            const modal = document.getElementById('booking-modal');
            const openModalBtn = document.getElementById('open-modal-btn');
            const closeModalBtn = document.getElementById('close-modal-btn');
            const cancelModalBtn = document.getElementById('cancel-modal-btn');
            const modalBackdrop = document.getElementById('modal-backdrop');
            const patientSelect = document.getElementById('patientId');
            const doctorSelect = document.getElementById('doctorId');
            const dateInput = document.getElementById('appointmentDate');
            const durationSelect = document.getElementById('durationMinutes');
            const availabilityPanel = document.getElementById('availability-panel');
            const availabilityContent = document.getElementById('availability-content');
            const form = document.getElementById('appointment-form');
            const modalAlert = document.getElementById('modal-alert');
            const submitBtn = document.getElementById('submit-btn');
            const btnText = submitBtn.querySelector('.btn-text');
            const btnSpinner = submitBtn.querySelector('.btn-spinner');

            const token = localStorage.getItem('jwt_token');
            const GAP_MINUTES = 45; // Required buffer between this doctor's appointments

            function authHeaders(json = false) {
                const h = {};
                if (token) h['Authorization'] = `Bearer ${token}`;
                if (json) h['Content-Type'] = 'application/json';
                return h;
            }

            // 0. Populate the "Doctor" filter dropdown with registered doctors
            async function loadFilterDoctors() {
                try {
                    const response = await fetch('/api/users/doctors', { headers: authHeaders() });
                    const result = await response.json();
                    if (response.ok && result.success && result.data.length > 0) {
                        filterDoctor.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">All Doctors</option>' +
                            result.data.map(d => `<option value="${d.id}" style="background-color: #141d36; color: #e2e8f0;">Dr. ${escapeHtml(d.fullName)}</option>`).join('');
                    }
                } catch (error) {
                    // Keep default "All Doctors" option on failure
                }
            }

            filterDoctor.addEventListener('change', fetchAppointments);
            filterStatus.addEventListener('change', fetchAppointments);
            filterDate.addEventListener('change', fetchAppointments);
            clearFiltersBtn.addEventListener('click', () => {
                filterDoctor.value = '';
                filterStatus.value = '';
                filterDate.value = '';
                fetchAppointments();
            });

            // 1. Fetch and render appointments, applying any active filters
            async function fetchAppointments() {
                try {
                    const params = new URLSearchParams();
                    if (filterDoctor.value) params.set('doctorId', filterDoctor.value);
                    if (filterStatus.value) params.set('status', filterStatus.value);
                    if (filterDate.value) params.set('date', filterDate.value);

                    const url = '/api/appointments' + (params.toString() ? `?${params.toString()}` : '');
                    const response = await fetch(url, { headers: authHeaders() });
                    if (response.status === 401) { window.location.href = '/Account/Login'; return; }

                    const result = await response.json();
                    if (response.ok && result.success) {
                        renderTable(result.data);
                    } else {
                        renderError(result.message || 'Failed to fetch appointments.');
                    }
                } catch (error) {
                    renderError('An error occurred while communicating with the database.');
                }
            }

            function renderTable(appointments) {
                if (!appointments || appointments.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="5" class="py-12 text-center text-slate-500 text-sm font-medium">
                                No appointments scheduled.
                            </td>
                        </tr>
                    `;
                    return;
                }

                tableBody.innerHTML = appointments.map(a => {
                    const apptDate = new Date(a.appointmentDate);
                    const apptEnd = new Date(apptDate.getTime() + (a.durationMinutes || 30) * 60000);
                    const formattedDate = apptDate.toLocaleDateString('en-US', {
                        weekday: 'short', year: 'numeric', month: 'short', day: 'numeric'
                    });
                    const formattedTime = apptDate.toLocaleTimeString('en-US', {
                        hour: '2-digit', minute: '2-digit'
                    });
                    const formattedEndTime = apptEnd.toLocaleTimeString('en-US', {
                        hour: '2-digit', minute: '2-digit'
                    });

                    const statusColors = {
                        'Scheduled': 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400',
                        'Completed': 'bg-blue-500/10 border-blue-500/20 text-blue-400',
                        'Cancelled': 'bg-rose-500/10 border-rose-500/20 text-rose-400'
                    };
                    const statusCls = statusColors[a.status] || 'bg-amber-500/10 border-amber-500/20 text-amber-400';

                    return `
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="py-4 pr-4 text-xs font-semibold text-slate-400">
                                <div class="text-brand-primary text-sm font-bold">${formattedTime} - ${formattedEndTime}</div>
                                <div>${formattedDate}</div>
                            </td>
                            <td class="py-4 px-4 font-semibold text-slate-200">
                                ${escapeHtml(a.patient ? a.patient.fullName : 'N/A')}
                            </td>
                            <td class="py-4 px-4 text-xs font-medium text-slate-300">
                                Dr. ${escapeHtml(a.doctorName)}
                            </td>
                            <td class="py-4 px-4 text-xs font-medium text-slate-300">
                                ${escapeHtml(a.reason || 'General Visit')}
                            </td>
                            <td class="py-4 pl-4 text-right space-x-3 whitespace-nowrap">
                                <span class="inline-flex px-2.5 py-1 text-xs font-semibold rounded-lg border ${statusCls}">
                                    ${escapeHtml(a.status)}
                                </span>
                                ${a.status === 'Scheduled' ? `
                                <button onclick="cancelAppointment('${a.id}')" class="inline-flex items-center gap-1 text-xs font-bold text-rose-400 hover:text-rose-300 transition-colors ml-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                                    <span>Cancel</span>
                                </button>` : ''}
                            </td>
                        </tr>
                    `;
                }).join('');
            }

            // Global handler to cancel/delete an appointment
            window.cancelAppointment = async function(id) {
                if (!confirm('Are you sure you want to cancel and delete this appointment?')) {
                    return;
                }

                try {
                    const response = await fetch(`/api/appointments/${id}`, {
                        method: 'DELETE',
                        headers: authHeaders()
                    });

                    if (response.status === 401) { window.location.href = '/Account/Login'; return; }

                    const result = await response.json();
                    if (response.ok && result.success) {
                        fetchAppointments();
                    } else {
                        alert(result.message || 'Failed to cancel appointment.');
                    }
                } catch (error) {
                    alert('An error occurred while communicating with the server.');
                }
            };

            function renderError(message) {
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="py-12 text-center text-red-400 text-sm font-semibold">
                            ${escapeHtml(message)}
                        </td>
                    </tr>
                `;
            }

            // 2. Fetch patients for select list
            async function loadPatientsSelect() {
                try {
                    const response = await fetch('/api/patients', { headers: authHeaders() });
                    const result = await response.json();
                    if (response.ok && result.success) {
                        if (result.data.length === 0) {
                            patientSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">No patients registered. Please register a patient first.</option>';
                        } else {
                            patientSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">-- Choose Patient --</option>' +
                                result.data.map(p => `<option value="${p.id}" style="background-color: #141d36; color: #e2e8f0;">${escapeHtml(p.fullName)} (${escapeHtml(p.phoneNumber)})</option>`).join('');
                        }
                    } else {
                        patientSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">Failed to load patients</option>';
                    }
                } catch (error) {
                    patientSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">Network error loading patients</option>';
                }
            }

            // 3. Fetch doctors for select list (registered users with Role = Doctor)
            async function loadDoctorsSelect() {
                try {
                    const response = await fetch('/api/users/doctors', { headers: authHeaders() });
                    const result = await response.json();
                    if (response.ok && result.success) {
                        if (result.data.length === 0) {
                            doctorSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">No doctors registered yet.</option>';
                        } else {
                            doctorSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">-- Choose Doctor --</option>' +
                                result.data.map(d => `<option value="${d.id}" data-name="${escapeHtml(d.fullName)}" style="background-color: #141d36; color: #e2e8f0;">Dr. ${escapeHtml(d.fullName)}</option>`).join('');
                        }
                    } else {
                        doctorSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">Failed to load doctors</option>';
                    }
                } catch (error) {
                    doctorSelect.innerHTML = '<option value="" style="background-color: #141d36; color: #e2e8f0;">Network error loading doctors</option>';
                }
            }

            // 4. Load and render doctor's availability (booked slots) for the chosen date
            async function loadAvailability() {
                const doctorId = doctorSelect.value;
                const dateTimeVal = dateInput.value;

                if (!doctorId || !dateTimeVal) {
                    availabilityPanel.classList.add('hidden');
                    return;
                }

                const selectedDate = dateTimeVal.split('T')[0];
                availabilityPanel.classList.remove('hidden');
                availabilityContent.innerHTML = '<span class="inline-block w-3 h-3 border-2 border-brand-primary border-r-transparent rounded-full animate-spin align-middle mr-2"></span>Checking availability...';

                try {
                    const response = await fetch(`/api/appointments/availability?doctorId=${doctorId}&date=${selectedDate}`, { headers: authHeaders() });
                    const result = await response.json();

                    if (response.ok && result.success) {
                        const slots = result.data;
                        if (slots.length === 0) {
                            availabilityContent.innerHTML = `<span class="text-emerald-400 font-semibold">✓ Doctor is fully free on this date.</span>`;
                        } else {
                            const slotChips = slots.map(s => {
                                const startT = new Date(s.appointmentDate).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                                const endT = new Date(s.endTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                                return `<span class="inline-block px-2 py-1 rounded-md bg-rose-500/10 border border-rose-500/20 text-rose-300 text-xs font-semibold mr-1.5 mb-1.5">${startT} - ${endT} booked</span>`;
                            }).join('');
                            availabilityContent.innerHTML = `<div class="mb-1.5 text-slate-400">${slots.length} appointment(s) already booked for this doctor (need ${GAP_MINUTES} min gap before/after each):</div><div>${slotChips}</div>`;
                        }
                        checkSelectedSlotConflict(slots);
                    } else {
                        availabilityContent.innerHTML = '<span class="text-amber-400">Could not check availability.</span>';
                    }
                } catch (error) {
                    availabilityContent.innerHTML = '<span class="text-amber-400">Could not check availability.</span>';
                }
            }

            // Highlight a warning if the selected [start, end) window — expanded by the
            // required gap on both sides — overlaps an existing booked appointment.
            // Mirrors the server-side rule exactly so the user sees the warning before submitting.
            function checkSelectedSlotConflict(bookedSlots) {
                const dateTimeVal = dateInput.value;
                if (!dateTimeVal) return;

                const duration = parseInt(durationSelect.value, 10) || 30;
                const newStart = new Date(dateTimeVal);
                const newEnd = new Date(newStart.getTime() + duration * 60000);

                const conflict = bookedSlots.find(s => {
                    const existingStart = new Date(s.appointmentDate);
                    const existingEnd = new Date(s.endTime);
                    const blockedStart = new Date(existingStart.getTime() - GAP_MINUTES * 60000);
                    const blockedEnd = new Date(existingEnd.getTime() + GAP_MINUTES * 60000);
                    return newStart < blockedEnd && newEnd > blockedStart;
                });

                if (conflict) {
                    const cs = new Date(conflict.appointmentDate).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                    const ce = new Date(conflict.endTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                    showFieldError('appointmentDate', `Too close to an existing appointment (${cs} - ${ce}). Leave at least ${GAP_MINUTES} min before/after.`);
                } else {
                    clearFieldError('appointmentDate');
                }
            }

            // Modal Toggles
            function openModal() {
                modal.classList.remove('hidden');
                loadPatientsSelect();
                loadDoctorsSelect();
                availabilityPanel.classList.add('hidden');
            }

            function closeModal() {
                modal.classList.add('hidden');
                form.reset();
                resetErrors();
                availabilityPanel.classList.add('hidden');
            }

            openModalBtn.addEventListener('click', openModal);
            closeModalBtn.addEventListener('click', closeModal);
            cancelModalBtn.addEventListener('click', closeModal);
            modalBackdrop.addEventListener('click', closeModal);

            doctorSelect.addEventListener('change', loadAvailability);
            dateInput.addEventListener('change', loadAvailability);
            durationSelect.addEventListener('change', loadAvailability);

            // 5. Form submit (Book Appointment)
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                resetErrors();

                let isValid = true;
                const patientId = patientSelect.value;
                const doctorId = doctorSelect.value;
                const doctorOption = doctorSelect.options[doctorSelect.selectedIndex];
                const doctorName = doctorOption ? (doctorOption.dataset.name || '') : '';
                const appointmentDate = dateInput.value;
                const durationMinutes = parseInt(durationSelect.value, 10) || 30;
                const reason = document.getElementById('reason').value.trim();

                if (!patientId) {
                    showFieldError('patientId', 'Please select a patient.');
                    isValid = false;
                }

                if (!doctorId) {
                    showFieldError('doctorId', 'Please select a doctor.');
                    isValid = false;
                }

                if (!appointmentDate) {
                    showFieldError('appointmentDate', 'Appointment date and time is required.');
                    isValid = false;
                }

                if (!isValid) return;

                setLoading(true);
                try {
                    const response = await fetch('/api/appointments', {
                        method: 'POST',
                        headers: authHeaders(true),
                        body: JSON.stringify({ patientId, doctorId, doctorName, appointmentDate, durationMinutes, reason: reason || null })
                    });

                    if (response.status === 401) { window.location.href = '/Account/Login'; return; }

                    const result = await response.json();

                    if (response.ok && result.success) {
                        showModalAlert('Appointment scheduled successfully!', 'success');
                        setTimeout(() => {
                            closeModal();
                            fetchAppointments();
                        }, 1000);
                    } else if (response.status === 409) {
                        // Conflict: doctor or patient already booked at this time
                        showModalAlert(result.message || 'This time slot is already booked.', 'error');
                        setLoading(false);
                    } else {
                        showModalAlert(result.message || 'Scheduling failed.', 'error');
                        setLoading(false);
                    }
                } catch (error) {
                    showModalAlert('An error occurred. Please check your network connection.', 'error');
                    setLoading(false);
                }
            });

            function showFieldError(fieldId, message) {
                const input = document.getElementById(fieldId);
                const errorDiv = document.getElementById(`${fieldId}-error`);
                input.classList.add('border-red-500', 'focus:ring-red-500/20', 'focus:border-red-500');
                errorDiv.textContent = message;
            }

            function clearFieldError(fieldId) {
                const input = document.getElementById(fieldId);
                const errorDiv = document.getElementById(`${fieldId}-error`);
                input.classList.remove('border-red-500', 'focus:ring-red-500/20', 'focus:border-red-500');
                errorDiv.textContent = '';
            }

            function resetErrors() {
                modalAlert.className = 'hidden text-sm p-4 rounded-xl mb-4 border';
                modalAlert.innerHTML = '';
                document.querySelectorAll('input, select, textarea').forEach(el => {
                    el.classList.remove('border-red-500', 'focus:ring-red-500/20', 'focus:border-red-500');
                });
                document.querySelectorAll('[id$="-error"]').forEach(el => el.textContent = '');
            }

            function showModalAlert(message, type) {
                modalAlert.className = `text-sm p-4 rounded-xl mb-4 border ${type === 'success' ? 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400' : 'bg-red-500/10 border-red-500/20 text-red-400'}`;
                modalAlert.innerHTML = message;
            }

            function setLoading(isLoading) {
                if (isLoading) {
                    submitBtn.disabled = true;
                    btnText.classList.add('hidden');
                    btnSpinner.classList.remove('hidden');
                } else {
                    submitBtn.disabled = false;
                    btnText.classList.remove('hidden');
                    btnSpinner.classList.add('hidden');
                }
            }

            function escapeHtml(str) {
                if (!str) return '';
                return str
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            // Check if ?book=true query parameter is present to auto-open modal
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('book') === 'true') {
                openModal();
            }

            // Initial fetch
            loadFilterDoctors();
            fetchAppointments();

            // Live updates: poll every 5 seconds so new appointments booked by other
            // users (Receptionist, Doctor) appear automatically without manual refresh.
            setInterval(() => {
                fetchAppointments();
            }, 5000);
        });
    </script>
}
