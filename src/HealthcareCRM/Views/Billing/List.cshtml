@{
    ViewData["Title"] = "Billing";
}

<div class="space-y-6 animate-auth">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-heading font-extrabold text-white tracking-tight">Billing & Invoices</h1>
            <p class="text-slate-400 text-sm">Manage patient invoices and payment records</p>
        </div>
        <button id="create-invoice-btn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 hover:shadow-brand-primary/35 transition-all hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            Create Invoice
        </button>
    </div>

    <!-- Filter Bar -->
    <div class="bg-brand-card border border-white/5 rounded-2xl p-4 shadow-xl">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <div>
                <label class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Patient</label>
                <select id="filter-patient" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary transition-all text-sm">
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">All Patients</option>
                </select>
            </div>
            <div>
                <label class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">Status</label>
                <select id="filter-status" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-3 py-2.5 focus:outline-none focus:border-brand-primary transition-all text-sm">
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">All Statuses</option>
                    <option value="Unpaid" style="background-color: #141d36; color: #e2e8f0;">Unpaid</option>
                    <option value="PartiallyPaid" style="background-color: #141d36; color: #e2e8f0;">Partially Paid</option>
                    <option value="Paid" style="background-color: #141d36; color: #e2e8f0;">Paid</option>
                    <option value="Cancelled" style="background-color: #141d36; color: #e2e8f0;">Cancelled</option>
                </select>
            </div>
            <div>
                <label class="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1.5">From Date</label>
                <input type="date" id="filter-from" style="color-scheme: dark;" class="w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-slate-200 focus:outline-none focus:border-brand-primary transition-all text-sm" />
            </div>
            <div class="flex items-end">
                <button id="clear-filters-btn" class="w-full px-3 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Clear Filters</button>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-brand-card border border-white/5 rounded-xl p-4 shadow-lg">
            <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Total Invoices</p>
            <p id="stat-total" class="text-2xl font-heading font-extrabold text-white mt-1">—</p>
        </div>
        <div class="bg-brand-card border border-white/5 rounded-xl p-4 shadow-lg">
            <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Outstanding</p>
            <p id="stat-outstanding" class="text-2xl font-heading font-extrabold text-rose-400 mt-1">—</p>
        </div>
        <div class="bg-brand-card border border-white/5 rounded-xl p-4 shadow-lg">
            <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Collected</p>
            <p id="stat-collected" class="text-2xl font-heading font-extrabold text-emerald-400 mt-1">—</p>
        </div>
        <div class="bg-brand-card border border-white/5 rounded-xl p-4 shadow-lg">
            <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Unpaid Count</p>
            <p id="stat-unpaid-count" class="text-2xl font-heading font-extrabold text-amber-400 mt-1">—</p>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-brand-card border border-white/5 rounded-2xl p-6 shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="border-b border-white/5 text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        <th class="pb-3 pr-4">Invoice #</th>
                        <th class="pb-3 px-4">Patient</th>
                        <th class="pb-3 px-4">Date</th>
                        <th class="pb-3 px-4">Total</th>
                        <th class="pb-3 px-4">Paid</th>
                        <th class="pb-3 px-4">Balance</th>
                        <th class="pb-3 px-4">Status</th>
                        <th class="pb-3 pl-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="invoices-table-body" class="divide-y divide-white/5 align-middle">
                    <tr><td colspan="8" class="py-12 text-center text-slate-500">
                        <span class="inline-block w-8 h-8 border-2 border-brand-primary border-r-transparent rounded-full animate-spin"></span>
                        <p class="mt-2 text-xs font-semibold">Loading invoices...</p>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Invoice Modal -->
<div id="invoice-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="invoice-modal-backdrop"></div>
    <div class="relative bg-[#0f172a] border border-white/10 rounded-2xl shadow-2xl p-6 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-lg font-heading font-bold text-white">Create Invoice</h3>
            <button id="invoice-modal-close" class="text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div id="invoice-modal-alert" class="hidden text-sm p-4 rounded-xl border mb-4"></div>
        <div class="flex flex-col gap-4">
            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Patient *</label>
                <select id="inv-patientId" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" required>
                    <option value="" style="background-color: #141d36; color: #e2e8f0;">Loading patients...</option>
                </select>
                <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="inv-patient-error"></div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Due Date</label>
                    <input type="date" id="inv-dueDate" style="color-scheme: dark;" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" />
                </div>
                <div>
                    <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Appointment (Optional)</label>
                    <select id="inv-appointmentId" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm">
                        <option value="" style="background-color: #141d36; color: #e2e8f0;">None</option>
                    </select>
                </div>
            </div>

            <!-- Line Items -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <label class="text-slate-300 text-xs font-semibold uppercase tracking-wider">Invoice Items *</label>
                    <button type="button" id="add-item-btn" class="text-xs font-semibold text-brand-primary hover:text-brand-accent transition-colors flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add Item
                    </button>
                </div>
                <div id="items-container" class="flex flex-col gap-2"></div>
                <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="inv-items-error"></div>
            </div>

            <!-- Total -->
            <div class="flex justify-end">
                <div class="bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-right">
                    <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider">Total Amount</p>
                    <p id="inv-total-display" class="text-2xl font-heading font-extrabold text-white">Rs. 0.00</p>
                </div>
            </div>

            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Notes</label>
                <textarea id="inv-notes" rows="2" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm resize-none" placeholder="Any additional notes..."></textarea>
            </div>

            <div class="flex gap-3 mt-2">
                <button id="invoice-modal-cancel" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Cancel</button>
                <button id="invoice-modal-save" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold bg-brand-primary hover:bg-brand-primaryHover text-white shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
                    <span class="btn-text">Create Invoice</span>
                    <span class="btn-spinner hidden w-4 h-4 border-2 border-white border-r-transparent rounded-full animate-spin"></span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div id="payment-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="payment-modal-backdrop"></div>
    <div class="relative bg-[#0f172a] border border-white/10 rounded-2xl shadow-2xl p-6 w-full max-w-md">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-lg font-heading font-bold text-white">Record Payment</h3>
                <p class="text-slate-400 text-xs mt-0.5">Balance: <span id="pay-balance" class="text-white font-semibold"></span></p>
            </div>
            <button id="payment-modal-close" class="text-slate-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div id="payment-modal-alert" class="hidden text-sm p-4 rounded-xl border mb-4"></div>
        <div class="flex flex-col gap-4">
            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Amount (Rs.) *</label>
                <input type="number" id="pay-amount" min="0.01" step="0.01" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm" placeholder="0.00" />
                <div class="text-red-400 text-xs mt-1 min-h-[16px]" id="pay-amount-error"></div>
            </div>
            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Payment Method *</label>
                <select id="pay-method" style="color-scheme: dark; background-color: #141d36; color: #e2e8f0;" class="w-full border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all text-sm">
                    <option value="Cash" style="background-color: #141d36; color: #e2e8f0;">Cash</option>
                    <option value="Card" style="background-color: #141d36; color: #e2e8f0;">Card</option>
                    <option value="Bank Transfer" style="background-color: #141d36; color: #e2e8f0;">Bank Transfer</option>
                    <option value="Online" style="background-color: #141d36; color: #e2e8f0;">Online</option>
                </select>
            </div>
            <div>
                <label class="block text-slate-300 text-xs font-semibold uppercase tracking-wider mb-2">Reference (Optional)</label>
                <input type="text" id="pay-reference" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/20 transition-all placeholder:text-slate-600 text-sm" placeholder="Transaction ID, cheque number..." />
            </div>
            <div class="flex gap-3 mt-2">
                <button id="payment-modal-cancel" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold border border-white/10 hover:border-white/20 text-slate-300 hover:text-white transition-all">Cancel</button>
                <button id="payment-modal-save" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold bg-emerald-500 hover:bg-emerald-600 text-white transition-all flex items-center justify-center gap-2">
                    <span class="btn-text">Record Payment</span>
                    <span class="btn-spinner hidden w-4 h-4 border-2 border-white border-r-transparent rounded-full animate-spin"></span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('jwt_token');
    const tableBody = document.getElementById('invoices-table-body');
    const filterPatient = document.getElementById('filter-patient');
    const filterStatus = document.getElementById('filter-status');
    const filterFrom = document.getElementById('filter-from');
    const clearFiltersBtn = document.getElementById('clear-filters-btn');
    const createInvoiceBtn = document.getElementById('create-invoice-btn');
    const invoiceModal = document.getElementById('invoice-modal');
    const invoiceModalClose = document.getElementById('invoice-modal-close');
    const invoiceModalCancel = document.getElementById('invoice-modal-cancel');
    const invoiceModalSave = document.getElementById('invoice-modal-save');
    const invoiceModalBackdrop = document.getElementById('invoice-modal-backdrop');
    const invoiceModalAlert = document.getElementById('invoice-modal-alert');
    const paymentModal = document.getElementById('payment-modal');
    const paymentModalClose = document.getElementById('payment-modal-close');
    const paymentModalCancel = document.getElementById('payment-modal-cancel');
    const paymentModalSave = document.getElementById('payment-modal-save');
    const paymentModalBackdrop = document.getElementById('payment-modal-backdrop');
    const paymentModalAlert = document.getElementById('payment-modal-alert');
    const addItemBtn = document.getElementById('add-item-btn');
    const itemsContainer = document.getElementById('items-container');
    let pendingPaymentInvoiceId = null;

    function authHeaders(json = false) {
        const h = {};
        if (token) h['Authorization'] = `Bearer ${token}`;
        if (json) h['Content-Type'] = 'application/json';
        return h;
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
    }

    function fmt(amount) {
        return 'Rs. ' + parseFloat(amount || 0).toLocaleString('en-PK', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function statusBadge(status) {
        const map = {
            'Unpaid':        'bg-rose-500/10 border-rose-500/20 text-rose-400',
            'PartiallyPaid': 'bg-amber-500/10 border-amber-500/20 text-amber-400',
            'Paid':          'bg-emerald-500/10 border-emerald-500/20 text-emerald-400',
            'Cancelled':     'bg-slate-500/10 border-slate-500/20 text-slate-400'
        };
        const cls = map[status] || 'bg-white/10 border-white/20 text-slate-300';
        const label = status === 'PartiallyPaid' ? 'Partial' : status;
        return `<span class="inline-flex px-2.5 py-1 text-xs font-semibold rounded-lg border ${cls}">${label}</span>`;
    }

    // Load invoices with filters
    async function fetchInvoices() {
        try {
            const params = new URLSearchParams();
            if (filterPatient.value) params.set('patientId', filterPatient.value);
            if (filterStatus.value) params.set('status', filterStatus.value);
            if (filterFrom.value) params.set('dateFrom', filterFrom.value);
            const url = '/api/billing' + (params.toString() ? `?${params}` : '');
            const res = await fetch(url, { headers: authHeaders() });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            const result = await res.json();
            if (res.ok && result.success) {
                renderTable(result.data);
                updateStats(result.data);
            } else { renderError(result.message); }
        } catch { renderError('Network error.'); }
    }

    function renderTable(invoices) {
        if (!invoices || invoices.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="8" class="py-12 text-center text-slate-500 text-sm">No invoices found.</td></tr>`;
            return;
        }
        tableBody.innerHTML = invoices.map(inv => {
            const date = new Date(inv.invoiceDate).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' });
            const balance = inv.totalAmount - inv.amountPaid;
            const canPay = inv.status !== 'Paid' && inv.status !== 'Cancelled';
            const canCancel = inv.status !== 'Paid' && inv.status !== 'Cancelled';
            return `
            <tr class="hover:bg-white/5 transition-colors">
                <td class="py-4 pr-4 font-mono text-xs text-brand-primary font-semibold">${escapeHtml(inv.invoiceNumber)}</td>
                <td class="py-4 px-4 font-semibold text-slate-200 text-sm">${escapeHtml(inv.patient?.fullName || 'N/A')}</td>
                <td class="py-4 px-4 text-xs text-slate-400">${date}</td>
                <td class="py-4 px-4 text-sm font-semibold text-white">${fmt(inv.totalAmount)}</td>
                <td class="py-4 px-4 text-sm text-emerald-400 font-semibold">${fmt(inv.amountPaid)}</td>
                <td class="py-4 px-4 text-sm font-semibold ${balance > 0 ? 'text-rose-400' : 'text-slate-400'}">${fmt(balance)}</td>
                <td class="py-4 px-4">${statusBadge(inv.status)}</td>
                <td class="py-4 pl-4 text-right">
                    <div class="flex items-center justify-end gap-3">
                        <a href="/Billing/Detail/${inv.id}" class="text-xs font-bold text-slate-400 hover:text-white transition-colors">View</a>
                        ${canPay ? `<button onclick="openPaymentModal('${inv.id}', ${balance})" class="text-xs font-bold text-emerald-400 hover:text-emerald-300 transition-colors">Pay</button>` : ''}
                        ${canCancel ? `<button onclick="cancelInvoice('${inv.id}')" class="text-xs font-bold text-rose-400 hover:text-rose-300 transition-colors">Cancel</button>` : ''}
                    </div>
                </td>
            </tr>`;
        }).join('');
    }

    function updateStats(invoices) {
        document.getElementById('stat-total').textContent = invoices.length;
        const outstanding = invoices.filter(i => i.status !== 'Paid' && i.status !== 'Cancelled').reduce((s, i) => s + (i.totalAmount - i.amountPaid), 0);
        const collected = invoices.reduce((s, i) => s + i.amountPaid, 0);
        const unpaidCount = invoices.filter(i => i.status === 'Unpaid').length;
        document.getElementById('stat-outstanding').textContent = fmt(outstanding);
        document.getElementById('stat-collected').textContent = fmt(collected);
        document.getElementById('stat-unpaid-count').textContent = unpaidCount;
    }

    function renderError(msg) {
        tableBody.innerHTML = `<tr><td colspan="8" class="py-12 text-center text-red-400 text-sm font-semibold">${escapeHtml(msg)}</td></tr>`;
    }

    // Load patients into filter + invoice form
    async function loadPatients() {
        try {
            const res = await fetch('/api/patients', { headers: authHeaders() });
            const result = await res.json();
            if (res.ok && result.success && result.data.length > 0) {
                const opts = result.data.map(p => `<option value="${p.id}" style="background-color: #141d36; color: #e2e8f0;">${escapeHtml(p.fullName)}</option>`).join('');
                filterPatient.innerHTML = `<option value="" style="background-color: #141d36; color: #e2e8f0;">All Patients</option>` + opts;
                document.getElementById('inv-patientId').innerHTML = `<option value="" style="background-color: #141d36; color: #e2e8f0;">-- Choose Patient --</option>` + opts;
            }
        } catch {}
    }

    // Load appointments when patient is selected in invoice form
    document.getElementById('inv-patientId').addEventListener('change', async function() {
        const pid = this.value;
        const apptSelect = document.getElementById('inv-appointmentId');
        apptSelect.innerHTML = `<option value="" style="background-color: #141d36; color: #e2e8f0;">None</option>`;
        if (!pid) return;
        try {
            const res = await fetch(`/api/appointments?patientId=${pid}`, { headers: authHeaders() });
            const result = await res.json();
            if (res.ok && result.success) {
                result.data.forEach(a => {
                    const d = new Date(a.appointmentDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    const opt = document.createElement('option');
                    opt.value = a.id;
                    opt.textContent = `${d} — Dr. ${a.doctorName}`;
                    opt.style.cssText = 'background-color: #141d36; color: #e2e8f0;';
                    apptSelect.appendChild(opt);
                });
            }
        } catch {}
    });

    // Invoice Items Management
    function addItemRow(desc = '', price = '', qty = 1) {
        const row = document.createElement('div');
        row.className = 'item-row grid grid-cols-12 gap-2 items-start';
        row.innerHTML = `
            <div class="col-span-6">
                <input type="text" placeholder="Description (e.g. Consultation Fee)" value="${escapeHtml(desc)}"
                    class="item-desc w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-slate-200 focus:outline-none focus:border-brand-primary text-sm placeholder:text-slate-600" />
            </div>
            <div class="col-span-3">
                <input type="number" placeholder="Price" value="${price}" min="0" step="0.01"
                    class="item-price w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-slate-200 focus:outline-none focus:border-brand-primary text-sm" />
            </div>
            <div class="col-span-2">
                <input type="number" placeholder="Qty" value="${qty}" min="1"
                    class="item-qty w-full bg-white/5 border border-white/10 rounded-xl px-3 py-2.5 text-slate-200 focus:outline-none focus:border-brand-primary text-sm" />
            </div>
            <div class="col-span-1 flex items-center justify-center pt-2">
                <button type="button" class="remove-item text-slate-500 hover:text-rose-400 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>`;
        row.querySelector('.remove-item').addEventListener('click', () => { row.remove(); recalcTotal(); });
        row.querySelectorAll('input').forEach(inp => inp.addEventListener('input', recalcTotal));
        itemsContainer.appendChild(row);
        recalcTotal();
    }

    function recalcTotal() {
        let total = 0;
        document.querySelectorAll('.item-row').forEach(row => {
            const price = parseFloat(row.querySelector('.item-price').value) || 0;
            const qty = parseInt(row.querySelector('.item-qty').value) || 1;
            total += price * qty;
        });
        document.getElementById('inv-total-display').textContent = fmt(total);
    }

    addItemBtn.addEventListener('click', () => addItemRow());

    // Invoice Modal
    function openInvoiceModal() {
        invoiceModal.classList.remove('hidden');
        invoiceModalAlert.className = 'hidden text-sm p-4 rounded-xl border mb-4';
        itemsContainer.innerHTML = '';
        addItemRow('Consultation Fee', '', 1);
        document.getElementById('inv-total-display').textContent = 'Rs. 0.00';
    }
    function closeInvoiceModal() { invoiceModal.classList.add('hidden'); }
    createInvoiceBtn.addEventListener('click', openInvoiceModal);
    invoiceModalClose.addEventListener('click', closeInvoiceModal);
    invoiceModalCancel.addEventListener('click', closeInvoiceModal);
    invoiceModalBackdrop.addEventListener('click', closeInvoiceModal);

    invoiceModalSave.addEventListener('click', async () => {
        const patientId = document.getElementById('inv-patientId').value;
        const dueDate = document.getElementById('inv-dueDate').value;
        const appointmentId = document.getElementById('inv-appointmentId').value;
        const notes = document.getElementById('inv-notes').value.trim();
        document.getElementById('inv-patient-error').textContent = '';
        document.getElementById('inv-items-error').textContent = '';

        if (!patientId) { document.getElementById('inv-patient-error').textContent = 'Please select a patient.'; return; }

        const items = [];
        let itemsValid = true;
        document.querySelectorAll('.item-row').forEach(row => {
            const desc = row.querySelector('.item-desc').value.trim();
            const price = parseFloat(row.querySelector('.item-price').value);
            const qty = parseInt(row.querySelector('.item-qty').value);
            if (!desc || isNaN(price) || price <= 0 || isNaN(qty) || qty <= 0) itemsValid = false;
            else items.push({ description: desc, unitPrice: price, quantity: qty });
        });

        if (items.length === 0) { document.getElementById('inv-items-error').textContent = 'Add at least one item.'; return; }
        if (!itemsValid) { document.getElementById('inv-items-error').textContent = 'All items must have a description, valid price, and quantity.'; return; }

        const btnText = invoiceModalSave.querySelector('.btn-text');
        const btnSpinner = invoiceModalSave.querySelector('.btn-spinner');
        invoiceModalSave.disabled = true; btnText.classList.add('hidden'); btnSpinner.classList.remove('hidden');

        try {
            const res = await fetch('/api/billing', {
                method: 'POST',
                headers: authHeaders(true),
                body: JSON.stringify({ patientId, appointmentId: appointmentId || null, dueDate: dueDate || null, notes: notes || null, items })
            });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            const result = await res.json();
            if (res.ok && result.success) {
                closeInvoiceModal();
                fetchInvoices();
            } else {
                invoiceModalAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
                invoiceModalAlert.textContent = result.message || 'Failed to create invoice.';
            }
        } catch {
            invoiceModalAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
            invoiceModalAlert.textContent = 'An error occurred.';
        } finally {
            invoiceModalSave.disabled = false; btnText.classList.remove('hidden'); btnSpinner.classList.add('hidden');
        }
    });

    // Payment Modal
    window.openPaymentModal = function(invoiceId, balance) {
        pendingPaymentInvoiceId = invoiceId;
        document.getElementById('pay-balance').textContent = fmt(balance);
        document.getElementById('pay-amount').value = '';
        document.getElementById('pay-amount-error').textContent = '';
        paymentModalAlert.className = 'hidden text-sm p-4 rounded-xl border mb-4';
        paymentModal.classList.remove('hidden');
    };
    function closePaymentModal() { paymentModal.classList.add('hidden'); pendingPaymentInvoiceId = null; }
    paymentModalClose.addEventListener('click', closePaymentModal);
    paymentModalCancel.addEventListener('click', closePaymentModal);
    paymentModalBackdrop.addEventListener('click', closePaymentModal);

    paymentModalSave.addEventListener('click', async () => {
        const amount = parseFloat(document.getElementById('pay-amount').value);
        const method = document.getElementById('pay-method').value;
        const reference = document.getElementById('pay-reference').value.trim();
        document.getElementById('pay-amount-error').textContent = '';

        if (!amount || amount <= 0) { document.getElementById('pay-amount-error').textContent = 'Enter a valid amount.'; return; }

        const btnText = paymentModalSave.querySelector('.btn-text');
        const btnSpinner = paymentModalSave.querySelector('.btn-spinner');
        paymentModalSave.disabled = true; btnText.classList.add('hidden'); btnSpinner.classList.remove('hidden');

        try {
            const res = await fetch(`/api/billing/${pendingPaymentInvoiceId}/payment`, {
                method: 'POST',
                headers: authHeaders(true),
                body: JSON.stringify({ amount, method, reference: reference || null })
            });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            const result = await res.json();
            if (res.ok && result.success) {
                closePaymentModal();
                fetchInvoices();
            } else {
                paymentModalAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
                paymentModalAlert.textContent = result.message || 'Failed to record payment.';
            }
        } catch {
            paymentModalAlert.className = 'text-sm p-4 rounded-xl border mb-4 bg-red-500/10 border-red-500/20 text-red-400';
            paymentModalAlert.textContent = 'An error occurred.';
        } finally {
            paymentModalSave.disabled = false; btnText.classList.remove('hidden'); btnSpinner.classList.add('hidden');
        }
    });

    // Cancel Invoice
    window.cancelInvoice = async function(invoiceId) {
        if (!confirm('Cancel this invoice? This cannot be undone for paid invoices.')) return;
        try {
            const res = await fetch(`/api/billing/${invoiceId}`, { method: 'DELETE', headers: authHeaders() });
            const result = await res.json();
            if (res.ok && result.success) fetchInvoices();
            else alert(result.message || 'Failed to cancel invoice.');
        } catch { alert('An error occurred.'); }
    };

    // Filters
    filterPatient.addEventListener('change', fetchInvoices);
    filterStatus.addEventListener('change', fetchInvoices);
    filterFrom.addEventListener('change', fetchInvoices);
    clearFiltersBtn.addEventListener('click', () => {
        filterPatient.value = ''; filterStatus.value = ''; filterFrom.value = '';
        fetchInvoices();
    });

    // Init
    loadPatients();
    fetchInvoices();
    setInterval(fetchInvoices, 10000);
});
</script>
}
